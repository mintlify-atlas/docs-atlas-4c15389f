  "keyFeatures": [
    "Location-based challenge completion with GPS verification",
    "Aura points system with tiered progression (25, 75, 150, 300, 500 pts)",
    "Social feed with likes and photo proof submissions",
    "Global leaderboard with streak tracking",
    "Supabase-backed authentication with email OTP verification",
    "Image upload for challenge proof via Supabase Storage",
    "Admin role for creating and managing challenges",
    "Content moderation via community flagging system"
